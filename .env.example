# AIDAG Chain Environment Variables
# Copy this file to .env.local and fill in your values

# Blockchain RPC URLs
NEXT_PUBLIC_BSC_RPC=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_ETH_RPC=https://eth.llamarpc.com
NEXT_PUBLIC_CHAIN_ID=56

# Contract Addresses
NEXT_PUBLIC_TOKEN_CONTRACT=0xe6B06f7C63F6AC84729007ae8910010F6E721041
NEXT_PUBLIC_PRESALE_CONTRACT=0x...

# Wallet Addresses
NEXT_PUBLIC_DAO_WALLET=0xC16eC985D98Db96DE104Bf1e39E1F2Fdb9a712E9
NEXT_PUBLIC_FOUNDER_WALLET=0x...
NEXT_PUBLIC_OPERATION_WALLET=0x...

# Tokenomics
NEXT_PUBLIC_TOKEN_SUPPLY=21000000
NEXT_PUBLIC_FOUNDER_COINS=3001000
NEXT_PUBLIC_FOUNDER_LOCK_PERIOD=1

# Presale Prices (USD)
NEXT_PUBLIC_PRESALE_STAGE1=0.078
NEXT_PUBLIC_PRESALE_STAGE2=0.093
NEXT_PUBLIC_LISTING_PRICE=0.12
NEXT_PUBLIC_PRESALE_TARGET=10000000

# DAO
NEXT_PUBLIC_DAO_MEMBERSHIP_FEE=5

# Site
NEXT_PUBLIC_SITE_URL=https://aidag-chain.com
NEXT_PUBLIC_TWITTER=https://twitter.com/aidagDAO
NEXT_PUBLIC_TELEGRAM=https://t.me/Aidag_Chain_Global_Community
NEXT_PUBLIC_LOGO_URL=/logo.png
